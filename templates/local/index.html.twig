{% extends 'base.html.twig' %}

{% block title %}Local index{% endblock %}

{% block body %}
    <h1>Local index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Type_local</th>
                <th>Adresse</th>
                <th>Code postal</th>
                <th>Ville</th>
                <th>Surface_m2</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for local in locals %}
            <tr>
                <td>{{ local.id }}</td>
                <td>{{ local.typeLocal }}</td>
                <td>{{ local.adresse }}</td>
                <td>{{ local.codePostal }}</td>
                <td>{{ local.ville }}</td>
                <td>{{ local.surfaceM2 }}</td>
                <td>
                    <a href="{{ path('app_local_show', {'id': local.id}) }}">show</a>
                    <a href="{{ path('app_local_edit', {'id': local.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_local_new') }}">Create new</a>
{% endblock %}
