{% extends 'base_web.html.twig' %}

{% block title %}Prestations — Administration{% endblock %}

{% block body %}
<div class="container-fluid px-4">
  <div class="page-inner">

    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h1 class="fw-bold mb-1">Prestations</h1>
        <p class="text-muted mb-0">Liste de toutes les prestations</p>
      </div>
      <a href="{{ path('app_prestation_new') }}" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Nouvelle prestation
      </a>
    </div>

    <div class="card">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Id</th>
                <th>Code</th>
                <th>Libellé</th>
                <th>Description</th>
                <th>Types de locaux</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
            {% for prestation in prestations %}
              <tr>
                <td>{{ prestation.id }}</td>
                <td><span class="badge bg-secondary">{{ prestation.codePrestation }}</span></td>
                <td class="fw-semibold">{{ prestation.libelle }}</td>
                <td>{{ prestation.description|length > 80 ? prestation.description|slice(0, 80) ~ '…' : prestation.description }}</td>
                <td>{{ prestation.typesLocal ? prestation.typesLocal|join(', ') : 'Tous' }}</td>
                <td class="text-end">
                  <a href="{{ path('app_prestation_show', {'id': prestation.id}) }}" class="btn btn-sm btn-outline-primary me-1">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href="{{ path('app_prestation_edit', {'id': prestation.id}) }}" class="btn btn-sm btn-outline-warning">
                    <i class="fas fa-pen"></i>
                  </a>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="6" class="text-center text-muted py-4">
                  <i class="fas fa-inbox fa-2x d-block opacity-25 mb-2"></i>
                  Aucune prestation trouvée
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}
