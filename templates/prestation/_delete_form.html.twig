<form method="post" action="{{ path('app_prestation_delete', {'id': prestation.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette prestation ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ prestation.id) }}">
    <button class="btn btn-danger btn-sm">
      <i class="fas fa-trash me-1"></i>Supprimer
    </button>
</form>
