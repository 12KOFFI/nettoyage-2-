{% extends 'base_web.html.twig' %}

{% block title %}Nouvelle prestation — Administration{% endblock %}

{% block body %}
<div class="container-fluid px-4">
  <div class="page-inner">

    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h1 class="fw-bold mb-1">Nouvelle prestation</h1>
        <p class="text-muted mb-0">Créer une nouvelle prestation</p>
