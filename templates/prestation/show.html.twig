{% extends 'base_web.html.twig' %}

{% block title %}Prestation — {{ prestation.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid px-4">
  <div class="page-inner">

    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h1 class="fw-bold mb-1">{{ prestation.libelle }}</h1>
        <p class="text-muted mb-0">Détails de la prestation</p>
      </div>
      <div class="d-flex gap-2">
        <a href="{{ path('app_prestation_index') }}" class="btn btn-outline-secondary">
          <i class="fas fa-arrow-left me-1"></i>Retour
        </a>
        <a href="{{ path('app_prestation_edit', {'id': prestation.id}) }}" class="btn btn-warning">
          <i class="fas fa-pen me-1"></i>Modifier
        </a>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <table class="table mb-0">
          <tbody>
            <tr>
              <th style="width:200px">Id</th>
              <td>{{ prestation.id }}</td>
            </tr>
            <tr>
              <th>Code prestation</th>
              <td><span class="badge bg-secondary">{{ prestation.codePrestation }}</span></td>
            </tr>
            <tr>
              <th>Libellé</th>
              <td>{{ prestation.libelle }}</td>
            </tr>
            <tr>
              <th>Description</th>
              <td>{{ prestation.description }}</td>
            </tr>
            <tr>
              <th>Types de locaux</th>
              <td>{{ prestation.typesLocal ? prestation.typesLocal|join(', ') : 'Tous' }}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="card-footer text-end">
        {{ include('prestation/_delete_form.html.twig') }}
      </div>
    </div>

  </div>
</div>
{% endblock %}
